config wifi-device 'radio0'
	option type 'mac80211'
	option channel '11' #1, 6, or 11
	option hwmode '11g'
	option path 'platform/soc/18000000.wifi'
	option htmode 'HE20'
	option country 'US'
	option txpower '30'
	option cell_density '2'
	list hostapd_options 'ssid_protection=1'

config wifi-iface '24Example'
	option device 'radio0'
	option network 'lan'
	option mode 'ap'
	option ssid 'Example'
	option encryption 'sae'
	option key 'password for wpa3 devices'
	option ieee80211w '2'
	option ocv '1'
	option wpa_disable_eapol_key_retries '1'
	option isolate '0'
	option bridge_isolate '0'
	option macaddr 'random'

config wifi-device 'radio1'
	option type 'mac80211'
	option channel '100'
	option hwmode '11a'
	option path 'platform/soc/18000000.wifi+1'
	option htmode 'HE160'
	option country 'US'
	option txpower '30'
	option cell_density '2'
	list hostapd_options 'ssid_protection=1'

config wifi-iface '5Example'
	option device 'radio1'
	option network 'lan'
	option mode 'ap'
	option ssid 'Example'
	option encryption 'sae'
	option key 'password for wpa3 devices'
	option ieee80211w '2'
	option ocv '1'
	option wpa_disable_eapol_key_retries '1'
	option isolate '0'
	option bridge_isolate '0'
	option macaddr 'random'
